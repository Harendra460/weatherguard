# --- Server ---
PORT=4000
NODE_ENV=development
ADMIN_WEB_URL=http://localhost:5173
USER_WEB_URL=http://localhost:5175
API_PUBLIC_URL=http://localhost:4000

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/weatherguard

# --- Auth (Google OAuth2) ---
# Create credentials at https://console.cloud.google.com (OAuth 2.0 Client ID).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated emails that are auto-promoted to ADMIN on first login.
ADMIN_EMAILS=you@example.com

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_USERNAME=YourBot
# Secret path segment for the webhook so only Telegram can hit it.
TELEGRAM_WEBHOOK_SECRET=change-me

# --- Weather ---
# OpenWeatherMap API key. If empty, the service returns MOCK data so the
# whole pipeline still runs end-to-end without a key.
OPENWEATHER_API_KEY=
# Cron expression for the in-process alert job (default: every day at 07:00).
ALERT_CRON=0 7 * * *
# Set false to disable the in-process cron (e.g. on a free host that sleeps) and
# drive alerts from an external scheduler hitting POST /weather/run-cron.
ALERT_CRON_ENABLED=true
# Shared secret the external scheduler must send as the `x-cron-secret` header.
CRON_SECRET=change-me-to-a-long-random-string
